# =============================================================================
# MyFitCraft - Ortam Değişkenleri (Örnek)
# =============================================================================
# Bu dosyayı .env olarak kopyala ve gerçek değerlerle doldur.
# .env dosyası ASLA commit edilmemelidir (.gitignore'a ekli).
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Web App Config (ZORUNLU)
#
# 1. https://console.firebase.google.com/ -> Project Settings -> General
# 2. "Your apps" -> Web app -> Config'i kopyala
# 3. Aşağıdaki alanları kendi projenle değiştir
# -----------------------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Sentry (OPSİYONEL - production crash reporting)
#
# Yayına çıkmadan önce kullanmak istersen:
# 1. https://sentry.io 'da React Native projesi oluştur
# 2. DSN'i aşağıya yapıştır
# 3. EAS build sırasında otomatik aktif olur
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Geliştirici scriptleri (opsiyonel - prod build'e dahil edilmez)
#
# `scripts/auto-translate.js` egzersiz açıklamalarını otomatik çevirir.
# Sadece geliştirici makinende çalışır, kullanıcı cihazına ulaşmaz.
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=
